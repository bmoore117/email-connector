# Your Gmail address
GMAIL_USER=you@gmail.com

# App password from Google Account > Security > 2-Step Verification > App passwords
# Generate one scoped to "Mail" — do NOT use your real Gmail password
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# The Gmail label to fetch from. Emails in this label are treated as event sources.
# Create the label in Gmail and set up a filter to auto-label emails from your private groups.
GMAIL_LABEL=miami-social-event-source

# Output paths — set these to wherever your OpenClaw bot reads from
UPCOMING_EVENTS_PATH=/opt/email-connector/upcoming_events.json
PAST_EVENTS_PATH=/opt/email-connector/past_events.json
HEALTH_OUTPUT_PATH=/opt/email-connector/health.json
LOG_PATH=/opt/email-connector/connector.log

# Tracks already-processed Message-IDs to avoid duplicates across runs
PROCESSED_IDS_PATH=/opt/email-connector/.processed_ids

# Comma-separated list of Luma calendar slugs (e.g. FTLYR,hello_miami) to directly fetch
# upcoming events from. This broadens the connector beyond just Gmail emails.
LUMA_CALENDARS=FTLYR,hello_miami,labmiami,delphica

# --- TaskFlow / agent routing ---
# Slack user ID the agent should DM with its final message (i.e. you)
TASKFLOW_USER_TARGET=U0AL1GKMR6J

# Where to write the JSON trigger artifact the agent reads
TASKFLOW_TRIGGER_PATH=/opt/email-connector/miami-social-radar-trigger.json

# Gateway Webhooks plugin route that creates the TaskFlow.
# Since fetch_events.py runs on the same host as the Gateway, localhost is fine.
# The default Gateway mux port is 18789; check with `ss -tlnp | grep openclaw`
# if you've customised it.
TASKFLOW_WEBHOOK_URL=http://localhost:18789/plugins/webhooks/miami-social-radar

# Shared secret matching the webhook route's configured secret on the Gateway
TASKFLOW_WEBHOOK_SECRET=replace-with-a-strong-random-string

# Subagent session key the worker runs under. Must follow the
# `agent:<agentId>:subagent:<label>` convention so it benefits from
# subagent auto-archive, the `subagent` queue lane, and `/subagents list`
# visibility. Use the agent id from `openclaw sessions --all-agents --json`
# (default agent is `main`); the `<label>` is yours to choose.
TASKFLOW_CHILD_SESSION_KEY=agent:main:subagent:miami-social-radar